rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== FOYDALANUVCHILAR =====
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ===== E'LONLAR =====
    match /listings/{listingId} {
      // Hamma o'qiy oladi
      allow read: if true;

      // Login qilgan har kim e'lon bera oladi
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.followers >= 100;

      // Egasi yoki istalgan login qilgan user yangilay oladi (admin uchun)
      allow update: if request.auth != null;

      // O'chirish — faqat login qilganlar
      allow delete: if request.auth != null;
    }

    // ===== SAVDOLAR =====
    match /orders/{orderId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ===== CHAT =====
    match /chats/{listingId}/messages/{messageId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text.size() <= 1000;
      allow update, delete: if false;
    }

    // ===== ADMIN =====
    match /admin/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
