rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== FOYDALANUVCHILAR =====
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ===== E'LONLAR =====
    match /listings/{listingId} {
      // Hamma o'qiy oladi
      allow read: if true;
      // Faqat login qilgan va o'z uid si bilan
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.followers >= 100;
      // Yangilash — login qilganlar (admin moderatsiya uchun)
      allow update: if request.auth != null;
      // O'chirish — faqat login qilganlar
      allow delete: if request.auth != null;
    }

    // ===== SAVDOLAR =====
    match /orders/{orderId} {
      // O'qish — xaridor yoki sotuvchi
      allow read: if request.auth != null;
      // Yaratish — login qilganlar
      allow create: if request.auth != null;
      // Yangilash — login qilganlar
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ===== CHAT =====
    match /chats/{listingId}/messages/{messageId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text.size() <= 1000;
      allow update, delete: if false;
    }

    // ===== ADMIN SOZLAMALAR =====
    match /admin/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ===== WISHLIST =====
    match /users/{userId}/wishlist/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
